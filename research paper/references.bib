@book{mazzoleni_media_2003,
	title = {The {Media} and {Neo}-{Populism}: {A} {Contemporary} {Comparative} {Analysis}},
	isbn = {978-0-313-05149-4},
	shorttitle = {The {Media} and {Neo}-{Populism}},
	abstract = {Mazzoleni, Stewart, Horsfield, and their contributors analyze the two-way relationship of the mass media and the contemporary phenomenon of extreme right wing neo-populist political parties which emerged in the closing years of the 20th century across the world. The success of Jean-Marie Le Pen, leader of the neo-populist Front National, in the first French presidential ballot in April 2002 shows that these extremist parties have strong, if varying, electoral support. Drawn into reporting on the policies and antigovernment critiques of the new parties, the mass communication institutions, especially those engaged in news production, have been challenged by a variety of unconventional but effective political campaign strategies that caused many media professionals considerable challenge.Taking an approach informed by mass communication theory, this book analyzes eight case studies of the interaction of news media dynamics and neo-populism in Austria, Australia, France, Canada, India, Italy, the United States, and the Latin American region against the background of widespread disenchantment with traditional parties and the complacency and cynicism of popularly elected governments. Insights into media responses reveal how dependent on media coverage the neo-populist parties were and how, in many cases, the media were initially unequal to the confronting ideologies of the new parties. Although the news media exploited the new parties, new parties exploited the news media as well in quite shrewd and original ways. This is an important resource for scholars, students, and other researchers involved with political mass communications and right-wing political organizations.},
	language = {en},
	publisher = {Bloomsbury Publishing USA},
	author = {Mazzoleni, Gianpietro and Stewart, Julianne and Horsfield, Bruce},
	month = feb,
	year = {2003},
	note = {Google-Books-ID: uhErEQAAQBAJ},
	keywords = {Political Science / General},
	annote = {Research on populism has become very extensive over the last decade. Stronger Focus on European and to a lesser extent latin american context
Research focus shifted to populism as a form of communication. --{\textgreater} here my paper could connect to the literature
argues that the shift in communication is due to media populism (imperative of the media industry to go after the popular tastes, often measured by ratings.) --{\textgreater} earlier it was ratings, now its engagement and reach
reseasrchers need to make sure to distinguish popular from populist. --{\textgreater} sometimes they come together (e.g. Söder isst)
existing research focuses more on the supply side because it is easier to access empirical resources here.
},
}

@article{blumler_third_1999,
	title = {The {Third} {Age} of {Political} {Communication}: {Influences} and {Features}},
	volume = {16},
	issn = {1058-4609},
	shorttitle = {The {Third} {Age} of {Political} {Communication}},
	url = {https://doi.org/10.1080/105846099198596},
	doi = {10.1080/105846099198596},
	abstract = {This article identifies key changes in society and the media that have shaped political communication in many democracies over the postwar period. Three distinct ages are described. In the first, much political communication was subordinate to relatively strong and stable political institutions and beliefs. In the second, faced with a more mobile electorate, the parties increasingly "professionalized" and adapted their communications to the news values and formats of limited-channel television. In the third (still emerging) age of media abundance, political communication may be reshaped by five trends: intensified professionalizing imperatives, increased competitive pressures, anti-elitist populism, a process of "centrifugal diversification," and changes in how people receive politics. This system is full of tensions, sets new research priorities, and reopens long-standing issues of democratic theory.},
	number = {3},
	urldate = {2026-02-19},
	journal = {Political Communication},
	publisher = {Routledge},
	author = {BLUMLER, JAY G. and KAVANAGH, DENNIS},
	month = jul,
	year = {1999},
	note = {\_eprint: https://doi.org/10.1080/105846099198596},
	pages = {209--230},
	annote = {Distinguishes between 3 “ages” of political communication.


“…much political communication was subordinate to relatively strong and stable political institutions and beliefs”


“…faced with a more mobile electorate, the parties increasingly “professionalized” and adapted their communications to the news values and formats of limited-channel television.”


“In the third (still emerging) age of media abundance, political communication may be reshaped by five trends: intensified professionalizing imperatives, increased competitive pressures, anti-elitist populism, a process of “centrifugal diversification,” and changes in how people receive politics.”


Identifies 5 future research priorities:


“how political communicators and media organizations are navigating change, redefining their purposes, and resolving their conflicts”


Agenda setting: “Are media agendas diversifying across the many different outlets of political communication, and, if so, how are they being received by the audiences of those outlets?”


dissolving key boundaries: non-political genres mix increasingly with political ones, issues from any topic are easily politicized. political journalism becomes increasingly more entertainment


politicians know how the new type of communication works and aim to utilise it for their advantage. But do citizens know about it aswell and if so, how do they deal with it?


“For whom and in what ways, if any, are these populist approaches and programs involving? Do they cultivate different perceptions of what politicians are like as communicators and political problem solvers from those conveyed in the news, ads, and conventional interviews? What audience and citizen roles dothey encourage people to adopt?”



argues that “Media organizations are driven to seek ways of making politics more palatable and acceptable to audience members.” --{\textgreater} media outlets have been adjusting their language already before social media. General trend in communication began before. Interesting here: plot when social media platform was founded/emerged and when shift in political speeches occured.

},
	file = {Full Text PDF:C\:\\Users\\rober\\Zotero\\storage\\EXXM2UAU\\BLUMLER and KAVANAGH - 1999 - The Third Age of Political Communication Influences and Features.pdf:application/pdf},
