@incollection{benoit_text_nodate,
	title = {Text as {Data}: {An} {Overview}},
	booktitle = {Handbook of {Research} {Methods} in {Political} {Science} and {International} {Relations}},
	author = {Benoit},
	pages = {461--497},
	annote = {Text is always informative, but not information in the sense of data. It has to be abstracted in some way first. E.g. Transforming texts into a matrix format that includes only keywords allows for the usage of statistical models and machine learning. --{\textgreater} we destroy the ability to understand the text directly by converting it into quantifiable data.; Text as data does not make inferences neutral, societal stereotypes often remain encoded in word embeddings (context of DSM - Distributional Semantic Models).
Actors have an inner (true) state that cannot be observed (even by themselves). However, them articulating their political position is the closest thing we have to observing the inner state of actors as actions such as voting behaviour is subject to external circumstances such as party discipline or strategic voting.
Purely quantitative approach utilises machine learning. Enables researchers to not having to read text at all except for validating. supervised machine learning is based on a training set with predefined labels such as negative or positive and a test set without labels where the attributes of the training set such as quantity of words with certain labels is estimated. The key to good quality here is a good quality training set rather than the quantitiy of training texts in the set. Unsupervised learning does not have a seperate learning step. It creates clusters that maximise the difference between them and minimise differences within them. This is good for topical analyses but overall has less usage in political science.
},
}

@incollection{grimmer_text_nodate,
	title = {Text as {Data}: {The} {Promise} and {Pitfalls} of {Automatic} {Content} {Analysis} {Methods} for {Political} {Texts}},
	booktitle = {Handbook of {Research} {Methods} in {Political} {Science} and {International} {Relations}},
	author = {Grimmer, Justin and Stewart, Brandon M.},
	pages = {267--297},
	annote = {Machine learning can help reduce sample selection bias if done correctly
Four types of biases: Resource bias (texts often better reflect populations with more resources to produce, record, and store documents), Incentive bias (individuals as well as organizations have incentives to fail to record or to hide or destroy evidence that could cast them in a negative light. --{\textgreater} someone might post about positive aspects of their life rather than about negative ones), Medium bias (different medium, different content. Twitter has word limit, Instagram has loads of photos and videos, etc.), Retrieval bias (the type of data gathering affects the data, e.g. using keywords in titles to select books can introduce systematic bias by missing some and only  include specific books.)
},
}

